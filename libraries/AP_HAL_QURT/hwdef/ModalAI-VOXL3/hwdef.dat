# SPI devices
#           NAME
QURT_SPIDEV "INV3"

#  compass list
#       Driver   BusAndAddr External Rotation
COMPASS QMC5883L I2C:0:0x0d true     ROTATION_NONE

#  barometer list
#    Driver I2C Bus+Addr
BARO DPS310 I2C:2:0x77

#  IMU list
#   Driver Bus+Addr   Rotation
IMU BMI270 SPI:INV3   ROTATION_NONE

# Use GPS UART device id on apps proc. The device id maps to /dev/ttyHS<id> on the apps processor.
define APPS_GPS_UART 7
